---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { AUTHOR, QUOTE, SITE_DESCRIPTION, SITE_TITLE, TAGLINE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;
const recent = rest.slice(0, 5);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<div class="wrap">
		<section class="hero">
			<div class="hero-grid">
				<div class="hero-copy">
					<div class="prompt"><span class="g">$</span> whoami<span class="cursor" aria-hidden="true"></span></div>
					<h1>Komo&apos;s personal space</h1>
					<p class="sub">&ldquo;{QUOTE}&rdquo;</p>
					<div class="cta">
						<a class="btn primary" href="/blog">Read the blog</a>
						<a class="btn" href="/about">About me</a>
					</div>
					<div class="hero-note" aria-label="Topics">
						<span>automation</span>
						<span>AI agents</span>
						<span>small tools</span>
					</div>
				</div>

				<aside class="hero-panel" aria-label="Site dispatch">
					<div class="panel-inner">
						<div class="panel-top">
							<div class="lights" aria-hidden="true"><span></span><span></span><span></span></div>
							<span>komo@live:~/notes</span>
						</div>
						<div class="terminal-lines" aria-hidden="true">
							<div><span class="g">$</span> cat principles.txt</div>
							<div class="cmd">ship small</div>
							<div class="cmd">overengineer nothing</div>
							<div class="cmd">write down what survived production</div>
						</div>
						<div class="dispatch-card">
							<div class="kicker">current dispatch</div>
							<h2>{featured ? featured.data.title : TAGLINE}</h2>
							<p>
								{featured
									? featured.data.description
									: 'The archive is warming up. New build logs and agent notes will land here.'}
							</p>
						</div>
					</div>
				</aside>
			</div>
		</section>

		<section class="blk about" id="about">
			<div class="sec-head"><h2>whoami</h2></div>
			<div class="identity-grid">
				<div>
					<p>{AUTHOR.bio}</p>
					<p class="dim">
						This is a field notebook for the unglamorous layer: parsing messy inputs, wiring
						retries, and deciding which agent workflows are worth keeping.
					</p>
				</div>
				<div class="about-card">
					<dl>
						<dt>born</dt>
						<dd>{AUTHOR.born}</dd>
						<dt>edu</dt>
						<dd>{AUTHOR.edu}</dd>
						<dt>pronouns</dt>
						<dd>{AUTHOR.pronouns}</dd>
						<dt>mode</dt>
						<dd>{TAGLINE}</dd>
					</dl>
				</div>
			</div>
		</section>

		<section class="blk" id="featured">
			<div class="sec-head"><h2>Latest</h2></div>
			{
				featured ? (
					<a class="feature" href={`/blog/${featured.id}/`}>
						<div class="kicker">latest post</div>
						<h3>{featured.data.title}</h3>
						<p>{featured.data.description}</p>
						<div class="meta">
							<FormattedDate date={featured.data.pubDate} />
						</div>
					</a>
				) : (
					<div class="empty">
						<h3>The blog is staged but the first post has not shipped.</h3>
						<p>
							The design treats an empty archive as a valid state: quiet, intentional, and ready
							for the first build log.
						</p>
						<pre><span class="g">$</span> ls src/content/blog/
.gitkeep</pre>
						<div class="empty-actions">
							<a class="btn primary" href="/about">Read the short version</a>
							<a class="btn" href="/blog">Open archive</a>
						</div>
					</div>
				)
			}
		</section>

		<section class="blk" id="posts">
			<div class="sec-head">
				<h2>Blog</h2>
				{recent.length > 0 && <a href="/blog">archive -&gt;</a>}
			</div>
			{
				recent.length > 0 ? (
					<div class="post-list">
						{recent.map((post) => (
							<a class="post" href={`/blog/${post.id}/`}>
								<div class="top">
									<h3>{post.data.title}</h3>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<p>{post.data.description}</p>
							</a>
						))}
					</div>
				) : (
					<div class="topics" aria-label="Planned topics">
						<a class="topic" href="/blog">
							<h3>Build logs</h3>
							<p>Small command-line tools and the decisions behind them.</p>
						</a>
						<a class="topic" href="/blog">
							<h3>Agents, honestly</h3>
							<p>What works, what breaks, and what is just a loop with better manners.</p>
						</a>
						<a class="topic" href="/blog">
							<h3>Plumbing</h3>
							<p>Parsing, retries, queues, cron, and the boring 80% nobody demos.</p>
						</a>
					</div>
				)
			}
		</section>
	</div>
</BaseLayout>
