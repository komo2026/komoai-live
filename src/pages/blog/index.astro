---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Blog · komo.sh`} description="Notes on small tools, AI agents, and the plumbing that keeps systems running.">
	<div class="wrap">
		<section class="hero" style="padding:56px 0 28px;">
			<div class="prompt"><span class="g">$</span> ls -t posts/</div>
			<h1>Blog</h1>
			<p class="sub">Build logs, agent experiments, and the boring 80% nobody demos.</p>
		</section>

		<section class="blk" style="border-bottom:none;">
			{
				posts.length > 0 ? (
					posts.map((post) => (
						<a class="post" href={`/blog/${post.id}/`}>
							<div class="top">
								<h3>{post.data.title}</h3>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</div>
							<p>{post.data.description}</p>
						</a>
					))
				) : (
					<div class="empty">
						<span class="g">$</span> find posts/ -name '*.md'
						<br />
						<span class="c"># 0 results. the archive is empty for now —</span>
						<br />
						<span class="c"># new posts will show up here as they ship.</span>
					</div>
				)
			}
		</section>
	</div>
</BaseLayout>
