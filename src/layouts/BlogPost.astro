---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from './BaseLayout.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, coverImage, seoTitle, seoDescription } =
	Astro.props;
---

<BaseLayout
	title={seoTitle ?? title}
	description={seoDescription ?? description}
	image={coverImage}
>
	<article class="wrap">
		<header class="article-head">
			<a class="back-link" href="/blog">&lt;- all posts</a>
			<div class="meta">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<>
							{' / updated '}
							<FormattedDate date={updatedDate} />
						</>
					)
				}
			</div>
			<h1>{title}</h1>
			{description && <p class="desc">{description}</p>}
			{
				coverImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={coverImage} alt="" loading="eager" />
					</div>
				)
			}
		</header>
		<div class="prose" style="padding:34px 0 64px;">
			<slot />
		</div>
	</article>
</BaseLayout>
