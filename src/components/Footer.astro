---
import { SOCIAL_LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site">
	<div class="wrap">
		<div class="foot">
			<div class="brand">
				<span class="brand-mark" aria-hidden="true">k</span>
				<span>komo.sh</span>
			</div>
			<nav class="socials" aria-label="Elsewhere">
				{
					SOCIAL_LINKS.map((s) => (
						<a href={s.href} target="_blank" rel="me noopener">
							{s.label}
						</a>
					))
				}
			</nav>
		</div>
		<div class="colophon">&copy; {year} komo / personal space / built with Astro</div>
	</div>
</footer>
