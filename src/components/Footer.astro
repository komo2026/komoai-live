---
import { SOCIAL_LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site">
	<div class="wrap">
		<div class="foot">
			<div class="brand"><span class="b">komo</span>.sh</div>
			<nav class="socials" aria-label="Elsewhere">
				{
					SOCIAL_LINKS.map((s) => (
						<a href={s.href} target="_blank" rel="me noopener">
							{s.label}
						</a>
					))
				}
			</nav>
		</div>
		<div class="colophon">© {year} komo · personal space</div>
	</div>
</footer>
