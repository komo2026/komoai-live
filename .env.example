# komoai.live — build-time environment (Hashnode headless CMS)
# Copy to .env for local builds. On Vercel, set these as Project env vars
# (Production + Preview). On the laptop these live in komo's secrets.env.
#
# Hashnode Personal Access Token (Pro). Used as `Authorization: Bearer <token>`.
# GraphQL read access is Pro-gated, so this is required to pull content.
HASHNODE_TOKEN=

# Publication host. Optional — defaults to komoai.live when unset.
HASHNODE_PUBLICATION_HOST=komoai.live
